@startuml Диаграмма активности - Работа агента и коммерции

title Диаграмма активности: Обработка заявки рекламным агентом и коммерческим отделом

|Рекламный агент|
start
:Войти в систему;

:Открыть список
назначенных заявок;

|Клиентская часть|
:Запросить заявки
агента из БД;

|Серверная часть|
:Получить запрос;

:Выполнить SELECT
WHERE agent_id = ?;

:Вернуть список
заявок;

|Клиентская часть|
:Отобразить таблицу
с заявками;

|Рекламный агент|
:Выбрать заявку
со статусом "in_progress";

:Просмотреть детали:
- название шоу
- дата эфира
- длительность
- стоимость
- контакты клиента;

:Открыть чат
с клиентом;

|Клиентская часть|
:Подключиться к
комнате чата через
WebSocket;

|Серверная часть|
:Установить соединение
Socket.IO;

:Присоединить к
комнате: chat_${applicationId};

|Рекламный агент|
:Написать сообщение
клиенту;

:Уточнить требования
к рекламному ролику;

|Клиентская часть|
:Отправить сообщение
через WebSocket;

|Серверная часть|
fork
  :Сохранить сообщение
  в таблице chat_messages;
fork again
  :Отправить сообщение
  клиенту в реальном времени;
end fork

:Получить ответ
от клиента;

|Рекламный агент|
:Прочитать ответ
клиента;

:Согласовать все
детали размещения;

if (Клиент готов\nк размещению?) then (Да)
  :Подготовить материалы
  для коммерческого отдела;
  
  :Добавить комментарий
  к заявке;
  
  |Клиентская часть|
  :Отправить комментарий
  на сервер;
  
  |Серверная часть|
  :Сохранить комментарий
  в БД;
  
  |Рекламный агент|
  :Нажать "Передать
  в коммерцию";
  
  |Клиентская часть|
  :Отправить запрос
  на изменение статуса;
  
  |Серверная часть|
  :Обновить статус
  на "ready_for_review";
  
  fork
    :Сохранить изменение
    в БД;
  fork again
    :Создать уведомление
    для коммерческого отдела;
  end fork
  
  :Отправить уведомление
  через WebSocket;
  
  |Коммерческий отдел|
  :Получить уведомление
  "Заявка готова к проверке";
  
  :Открыть список
  заявок на проверку;
  
  |Клиентская часть|
  :Запросить заявки
  со статусом
  "ready_for_review";
  
  |Серверная часть|
  :Выполнить SELECT
  WHERE status = 'ready_for_review';
  
  :Вернуть список;
  
  |Клиентская часть|
  :Отобразить таблицу;
  
  |Коммерческий отдел|
  :Выбрать заявку;
  
  :Просмотреть:
  - детали заявки
  - комментарии агента
  - историю чата
  - данные клиента;
  
  :Проверить доступность
  времени эфира;
  
  |Клиентская часть|
  :Запросить расписание
  показов;
  
  |Серверная часть|
  :Проверить таблицу
  shows на конфликты;
  
  :Вернуть результат
  проверки;
  
  |Коммерческий отдел|
  :Изучить результат;
  
  :Проверить соответствие
  требованиям вещания;
  
  if (Всё в порядке?) then (Да)
    :Нажать "Одобрить
    заявку";
    
    |Клиентская часть|
    :Отправить запрос
    на одобрение;
    
    |Серверная часть|
    :Обновить статус
    на "approved";
    
    :Установить дату
    approved_at = NOW();
    
    fork
      :Рассчитать комиссию
      агента (5% от стоимости);
    fork again
      :Создать запись
      в таблице commissions;
    fork again
      :Создать уведомление
      для агента;
    fork again
      :Создать уведомление
      для клиента;
    end fork
    
    :Отправить уведомления
    через WebSocket;
    
    |Рекламный агент|
    :Получить уведомление
    "Заявка одобрена,
    комиссия: ₽XXXX";
    
    :Увидеть обновлённый
    статус заявки;
    
    :Перейти к созданию
    договора;
    note right
      Процесс создания договора
      описан в отдельной
      диаграмме активности
    end note
    
    #LightGreen:Заявка успешно
    одобрена;
    stop
    
  else (Нет, есть проблемы)
    :Нажать "Отклонить
    заявку";
    
    :Указать причину
    отклонения:
    - конфликт расписания
    - не соответствует требованиям
    - другая причина;
    
    |Клиентская часть|
    :Отправить запрос
    на отклонение;
    
    |Серверная часть|
    :Обновить статус
    на "rejected";
    
    :Сохранить причину
    отклонения;
    
    fork
      :Сохранить изменения
      в БД;
    fork again
      :Создать уведомление
      для агента;
    fork again
      :Создать уведомление
      для клиента;
    end fork
    
    :Отправить уведомления
    через WebSocket;
    
    |Рекламный агент|
    :Получить уведомление
    об отклонении;
    
    :Прочитать причину
    отклонения;
    
    :Открыть чат
    с клиентом;
    
    :Сообщить клиенту
    о проблемах;
    
    if (Можно исправить?) then (Да)
      :Согласовать новые
      условия с клиентом;
      
      :Обновить данные
      заявки;
      
      |Клиентская часть|
      :Отправить обновлённые
      данные;
      
      |Серверная часть|
      :Обновить заявку
      в БД;
      
      :Вернуть статус
      на "in_progress";
      
      |Рекламный агент|
      :Повторно передать
      в коммерцию;
      note right
        Возврат к этапу
        "Передать в коммерцию"
      end note
      
      #Yellow:Заявка отправлена
      на повторную проверку;
      stop
      
    else (Нет)
      :Закрыть заявку;
      
      |Клиентская часть|
      :Отправить запрос
      на закрытие;
      
      |Серверная часть|
      :Обновить статус
      на "cancelled";
      
      #LightCoral:Заявка окончательно
      отклонена;
      stop
    endif
  endif
  
else (Нет, нужны уточнения)
  |Рекламный агент|
  :Продолжить переписку
  с клиентом;
  
  :Запросить дополнительную
  информацию;
  
  #Yellow:Ожидание ответа
  от клиента;
  stop
endif

@enduml
