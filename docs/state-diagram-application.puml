@startuml Диаграмма состояний заявки

title Диаграмма состояний объекта "Рекламная заявка"

[*] --> Создание

state Создание {
  [*] --> ВводДанных
  ВводДанных --> РасчетСтоимости : заполнены основные поля
  РасчетСтоимости --> ПроверкаДанных : получена стоимость
  ПроверкаДанных --> ГотоваКОтправке : данные корректны
  ПроверкаДанных --> ВводДанных : данные некорректны
}

Создание --> Pending : отправить заявку

state Pending {
  [*] --> ОжиданиеНазначения
  ОжиданиеНазначения : entry / сохранить в БД
  ОжиданиеНазначения : entry / уведомить коммерцию
  ОжиданиеНазначения : do / ожидание назначения агента
}

Pending --> InProgress : назначить агента

state InProgress {
  [*] --> СвязьСКлиентом
  
  state СвязьСКлиентом {
    [*] --> ОткрытиеЧата
    ОткрытиеЧата --> ОбменСообщениями : чат открыт
    ОбменСообщениями --> СогласованиеДеталей : обсуждение
    СогласованиеДеталей --> ПодготовкаМатериалов : детали согласованы
  }
  
  СвязьСКлиентом --> ГотоваКПроверке : [все согласовано]
}

InProgress : entry / уведомить агента
InProgress : do / работа агента с клиентом
InProgress : exit / сохранить комментарии

InProgress --> ReadyForReview : передать в коммерцию

state ReadyForReview {
  [*] --> ОжиданиеПроверки
  ОжиданиеПроверки : entry / уведомить коммерческий отдел
  ОжиданиеПроверки : do / ожидание проверки
  
  ОжиданиеПроверки --> Проверка : начать проверку
  
  state Проверка {
    [*] --> АнализЗаявки
    АнализЗаявки --> ПроверкаРасписания : данные изучены
    ПроверкаРасписания --> ПроверкаТребований : расписание свободно
    ПроверкаТребований --> ПринятиеРешения : требования проверены
  }
}

ReadyForReview --> Approved : [проверка пройдена] одобрить
ReadyForReview --> Rejected : [проблемы выявлены] отклонить

state Approved {
  [*] --> РасчетКомиссии
  РасчетКомиссии --> УведомлениеУчастников : комиссия рассчитана
  УведомлениеУчастников : entry / уведомить агента
  УведомлениеУчастников : entry / уведомить клиента
  УведомлениеУчастників --> ГотоваКДоговору : [все уведомлены]
}

Approved : entry / установить approved_at
Approved : entry / рассчитать комиссию агента
Approved : exit / подготовить данные для договора

Approved --> ContractSent : создать договор

state ContractSent {
  [*] --> ДоговорСоздан
  ДоговорСоздан : entry / сгенерировать номер договора
  ДоговорСоздан : entry / сохранить договор в БД
  ДоговорСоздан --> ОжиданиеПросмотра : договор отправлен
}

ContractSent --> ContractViewed : клиент просмотрел договор
ContractViewed : entry / установить viewed_at

ContractViewed --> ContractDownloaded : клиент скачал договор
ContractDownloaded : entry / установить downloaded_at
ContractDownloaded : do / ожидание оплаты вне системы

ContractDownloaded --> Paid : зарегистрировать платеж

state Paid {
  [*] --> ПроверкаПлатежа
  ПроверкаПлатежа --> СохранениеПлатежа : сумма совпадает
  СохранениеПлатежа --> ОбновлениеКомиссии : платеж сохранен
  ОбновлениеКомиссии --> ЗавершениеОплаты : комиссия обновлена
}

Paid : entry / установить payment_date
Paid : entry / сохранить данные платежа
Paid : entry / обновить комиссию агента
Paid : exit / уведомить всех участников

Paid --> Completed : подтвердить завершение

state Completed {
  [*] --> АрхивированиеДанных
  АрхивированиеДанных : entry / переместить в архив
  АрхивированиеДанных : do / хранение истории
}

Completed --> [*]

state Rejected {
  [*] --> УказаниеПричины
  УказаниеПричины : entry / сохранить причину отклонения
  УказаниеПричины --> УведомлениеОбОтклонении : причина указана
  УведомлениеОбОтклонении : entry / уведомить агента
  УведомлениеОбОтклонении : entry / уведомить клиента
}

Rejected : entry / установить rejection_reason

Rejected --> InProgress : [можно исправить] вернуть агенту
Rejected --> Cancelled : [нельзя исправить] отменить окончательно

state Cancelled {
  [*] --> ЗакрытиеЗаявки
  ЗакрытиеЗаявки : entry / архивировать заявку
  ЗакрытиеЗаявки : entry / закрыть все связанные процессы
}

Cancelled --> [*]

note right of Pending
  Статус: pending
  Заявка создана,
  ожидает назначения
  рекламного агента
end note

note right of InProgress
  Статус: in_progress
  Агент работает с клиентом,
  согласовывает детали
  через чат
end note

note right of ReadyForReview
  Статус: ready_for_review
  Заявка передана
  на проверку в
  коммерческий отдел
end note

note right of Approved
  Статус: approved
  Заявка одобрена,
  рассчитана комиссия агента,
  можно создавать договор
end note

note right of Paid
  Статус: paid
  Клиент оплатил заявку,
  бухгалтер зарегистрировал
  платеж в системе
end note

note left of Rejected
  Статус: rejected
  Заявка отклонена
  коммерческим отделом
  с указанием причины
end note

note left of Cancelled
  Статус: cancelled
  Заявка окончательно
  отменена и закрыта
end note

@enduml
