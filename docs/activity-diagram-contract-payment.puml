@startuml Диаграмма активности - Создание договора и оплата

title Диаграмма активности: Процесс создания договора и регистрации оплаты

|Рекламный агент|
start
note right
  Условие: заявка должна
  быть в статусе "approved"
end note

:Войти в систему;

:Открыть одобренную
заявку;

:Проверить все детали
с клиентом;

if (Все детали\nсогласованы?) then (Да)
  :Нажать кнопку
  "Создать договор";
  
  |Клиентская часть|
  :Отправить запрос
  на создание договора;
  
  |Серверная часть|
  :Получить запрос;
  
  :Вызвать функцию
  генерации номера;
  note right
    generate_contract_number()
    Формат: DOG-2025-XXXXXX
  end note
  
  :Получить уникальный
  номер договора;
  
  :Собрать данные договора:
  - номер
  - ID заявки
  - ID клиента
  - ID агента
  - название шоу
  - дата эфира
  - стоимость
  - описание;
  
  fork
    :Сохранить договор
    в таблице contracts;
  fork again
    :Установить статус
    договора: "sent";
  fork again
    :Создать уведомление
    для клиента;
  end fork
  
  :Отправить уведомление
  через WebSocket;
  
  |Клиентская часть|
  :Получить подтверждение
  создания договора;
  
  |Рекламный агент|
  :Увидеть уведомление
  "Договор создан: DOG-2025-001234";
  
  |Заказчик|
  :Получить уведомление
  "Договор готов к просмотру";
  
  :Войти в раздел
  "Документы";
  
  |Клиентская часть|
  :Запросить список
  договоров;
  
  |Серверная часть|
  :Получить запрос;
  
  :Выбрать договоры
  из БД по customer_id;
  
  :Вернуть список
  договоров;
  
  |Клиентская часть|
  :Отобразить таблицу
  договоров;
  
  |Заказчик|
  :Найти нужный договор
  в списке;
  
  :Нажать "Просмотреть";
  
  |Серверная часть|
  :Обновить статус
  договора на "viewed";
  
  :Отметить read_at = NOW();
  
  |Клиентская часть|
  :Отобразить детали
  договора;
  
  |Заказчик|
  :Изучить условия
  договора;
  
  if (Согласен с\nусловиями?) then (Да)
    :Нажать "Скачать
    договор";
    
    |Клиентская часть|
    :Отправить запрос
    на скачивание;
    
    |Серверная часть|
    :Получить запрос;
    
    :Обновить статус
    договора на "downloaded";
    
    :Сгенерировать PDF
    документ;
    note right
      Использует библиотеку
      jspdf для формирования
      PDF файла с данными
    end note
    
    :Вернуть PDF файл;
    
    |Клиентская часть|
    :Скачать файл
    на устройство;
    
    |Заказчик|
    :Получить файл
    договора;
    
    :Произвести оплату
    (вне системы);
    note right
      Оплата через банк,
      терминал или другим
      способом
    end note
    
    |Бухгалтер|
    :Получить информацию
    об оплате;
    
    :Войти в систему;
    
    :Открыть раздел
    "Платежи";
    
    :Найти заявку
    по номеру;
    
    :Нажать "Зарегистрировать
    платёж";
    
    :Заполнить форму:
    - сумма платежа
    - способ оплаты
    - дата платежа;
    
    |Клиентская часть|
    :Отправить данные
    платежа на сервер;
    
    |Серверная часть|
    :Получить данные
    о платеже;
    
    :Проверить сумму
    с суммой заявки;
    
    if (Сумма\nсовпадает?) then (Да)
      fork
        :Обновить статус
        заявки на "paid";
      fork again
        :Сохранить данные
        платежа;
      fork again
        :Установить
        payment_date = NOW();
      fork again
        :Рассчитать окончательную
        комиссию агента;
      fork again
        :Обновить запись
        в таблице commissions;
      end fork
      
      fork
        :Создать уведомление
        для заказчика;
      fork again
        :Создать уведомление
        для агента;
      fork again
        :Создать уведомление
        для коммерции;
      end fork
      
      :Отправить уведомления
      через WebSocket;
      
      |Бухгалтер|
      :Увидеть подтверждение
      "Платёж зарегистрирован";
      
      |Заказчик|
      :Получить уведомление
      "Платёж подтверждён";
      
      |Рекламный агент|
      :Получить уведомление
      "Платёж получен, комиссия
      рассчитана";
      
      |Коммерческий отдел|
      :Получить уведомление
      "Заявка оплачена";
      
      #LightGreen:Процесс успешно
      завершён;
      stop
      
    else (Нет)
      |Серверная часть|
      :Вернуть ошибку
      "Неверная сумма";
      
      |Бухгалтер|
      :Увидеть сообщение
      об ошибке;
      
      :Проверить данные
      платежа;
      
      #LightCoral:Ошибка регистрации
      платежа;
      stop
    endif
    
  else (Нет)
    |Заказчик|
    :Связаться с агентом
    для уточнений;
    
    #Yellow:Требуются
    уточнения;
    stop
  endif
  
else (Нет)
  |Рекламный агент|
  :Продолжить переговоры
  с клиентом;
  
  #Yellow:Требуется
  согласование;
  stop
endif

@enduml
