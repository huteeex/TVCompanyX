@startuml Диаграмма активности - Создание и одобрение заявки

title Диаграмма активности: Создание и одобрение рекламной заявки

|Заказчик|
start
:Войти в систему;

:Открыть раздел
"Создать заявку";

:Выбрать шоу из списка;

:Указать дату и время эфира;

:Указать длительность
рекламного ролика (сек);

|Клиентская часть|
:Отправить запрос
на расчёт стоимости;

|Серверная часть|
:Получить параметры заявки;

:Найти шоу в базе данных;

:Получить базовую цену
за минуту;

:Рассчитать итоговую
стоимость;
note right
  Формула:
  стоимость = базовая_цена * 
  (длительность / 60)
end note

:Вернуть расчёт;

|Клиентская часть|
:Отобразить стоимость
пользователю;

|Заказчик|
:Просмотреть расчёт;

if (Согласен с ценой?) then (Да)
  :Заполнить описание
  рекламы;
  
  :Указать контактный
  телефон;
  
  :Подтвердить создание
  заявки;
  
  |Клиентская часть|
  :Отправить заявку
  на сервер;
  
  |Серверная часть|
  :Получить данные заявки;
  
  fork
    :Сохранить заявку в БД
    со статусом "pending";
  fork again
    :Создать уведомление для
    коммерческого отдела;
  end fork
  
  :Отправить уведомление
  через WebSocket;
  
  |Коммерческий отдел|
  :Получить уведомление
  о новой заявке;
  
  :Открыть список заявок;
  
  :Просмотреть детали
  заявки;
  
  :Назначить агента
  на заявку;
  
  |Серверная часть|
  :Обновить статус заявки
  на "in_progress";
  
  fork
    :Сохранить назначение
    агента в БД;
  fork again
    :Создать уведомление
    для агента;
  end fork
  
  |Рекламный агент|
  :Получить уведомление
  о назначении;
  
  :Открыть заявку;
  
  :Связаться с клиентом
  через чат;
  
  :Уточнить детали
  размещения;
  
  |Коммерческий отдел|
  :Провести анализ
  заявки;
  
  if (Заявка соответствует\nтребованиям?) then (Да)
    :Одобрить заявку;
    
    |Серверная часть|
    :Обновить статус
    на "approved";
    
    fork
      :Рассчитать комиссию
      агента;
    fork again
      :Создать запись
      в таблице комиссий;
    fork again
      :Отправить уведомления
      всем участникам;
    end fork
    
    |Рекламный агент|
    :Получить уведомление
    об одобрении;
    
    |Заказчик|
    :Получить уведомление
    об одобрении;
    
    :Просмотреть статус
    заявки: "Одобрена";
    
    #LightGreen:Заявка успешно
    одобрена;
    stop
    
  else (Нет)
    :Отклонить заявку;
    
    :Указать причину
    отклонения;
    
    |Серверная часть|
    :Обновить статус
    на "rejected";
    
    fork
      :Сохранить причину
      отклонения;
    fork again
      :Отправить уведомления
      клиенту и агенту;
    end fork
    
    |Заказчик|
    :Получить уведомление
    об отклонении;
    
    :Просмотреть причину
    отклонения;
    
    #LightCoral:Заявка отклонена;
    stop
  endif
  
else (Нет)
  |Заказчик|
  :Закрыть форму;
  
  #Yellow:Создание заявки
  отменено;
  stop
endif

@enduml
