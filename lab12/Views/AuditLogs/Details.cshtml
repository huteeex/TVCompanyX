@model Lab12TVCompanyX.Models.AuditLog
@using System.Text.Json
@{ ViewData["Title"] = "Аудит — детали"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Журнал аудита</a></li>
        <li class="breadcrumb-item active">Детали</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">Запись аудита #@Model.AuditId</div>
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4">Сущность</dt>
                <dd class="col-sm-8">@Model.EntityName</dd>
                <dt class="col-sm-4">ID записи</dt>
                <dd class="col-sm-8">@Model.EntityId</dd>
                <dt class="col-sm-4">Действие</dt>
                <dd class="col-sm-8">@Model.Action</dd>
                <dt class="col-sm-4">Кем выполнено</dt>
                <dd class="col-sm-8">@(Model.PerformedBy != null ? Model.PerformedBy.LastName + " " + Model.PerformedBy.FirstName : "система")</dd>
                <dt class="col-sm-4">Дата</dt>
                <dd class="col-sm-8">@Model.PerformedAt.ToString("dd.MM.yyyy HH:mm:ss")</dd>
                @if (Model.Data != null)
                {
                    <dt class="col-sm-4">Данные (JSON)</dt>
                    <dd class="col-sm-8">
                        <pre class="bg-light border rounded p-2 small mb-0" style="max-height:300px;overflow:auto;">@JsonSerializer.Serialize(JsonSerializer.Deserialize<object>(Model.Data.RootElement.GetRawText()), new JsonSerializerOptions { WriteIndented = true })</pre>
                    </dd>
                }
            </dl>
        </div>
        <div class="card-footer bg-transparent">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Список</a>
        </div>
    </div>
</div></div>
