@model Lab12TVCompanyX.Models.LoginViewModel
@{
    ViewData["Title"] = "Вход в систему";
    Layout = "_Layout";
}

<div class="row justify-content-center" style="margin-top:5rem">
    <div class="col-sm-10 col-md-6 col-lg-4">

        <div class="text-center mb-4 animate-fadeInUp">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="15" rx="2"/>
                <polyline points="17 2 12 7 7 2"/>
            </svg>
            <h5 class="mt-2 mb-0" style="color:var(--c-heading);font-weight:700;">ТВ Компания X</h5>
            <p class="text-muted small mb-0">Система управления рекламными заявками</p>
        </div>

        <div class="card animate-fadeInUp delay-1">
            <div class="card-body p-4">
                <h6 class="mb-3" style="font-weight:700;color:var(--c-heading);">Вход в систему</h6>
                <form asp-action="Login" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger py-2 small mb-3"
                         style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email"
                               class="form-control @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="you@example.com"
                               autocomplete="email" />
                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password"
                               class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="••••••••"
                               autocomplete="current-password" />
                        <span asp-validation-for="Password" class="invalid-feedback"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Войти</button>
                </form>
            </div>
        </div>

        <p class="text-center text-muted small mt-3 animate-fadeIn delay-2">
            Нет аккаунта?
            <a asp-controller="Account" asp-action="Register">Зарегистрироваться</a>
        </p>
    </div>
</div>
