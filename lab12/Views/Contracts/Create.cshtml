@model Lab12TVCompanyX.Models.Contract
@{ ViewData["Title"] = "Новый договор"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Договоры</a></li>
        <li class="breadcrumb-item active">Добавить</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">Новый договор</div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Заявка</label>
                    <select name="RequestId" class="form-select"
                            asp-items="@(ViewBag.RequestId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                </div>
                <div class="mb-3">
                    <label asp-for="ContractNumber" class="form-label fw-semibold">Номер договора</label>
                    <input asp-for="ContractNumber" class="form-control" />
                    <span asp-validation-for="ContractNumber" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ContractDate" class="form-label fw-semibold">Дата договора</label>
                    <input asp-for="ContractDate" class="form-control" type="date" />
                    <span asp-validation-for="ContractDate" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Amount" class="form-label fw-semibold">Сумма</label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="AgentCommission" class="form-label fw-semibold">Комиссия агента</label>
                    <input asp-for="AgentCommission" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="AgentCommission" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4">Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div></div>
