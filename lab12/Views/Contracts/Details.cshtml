@model Lab12TVCompanyX.Models.Contract
@{ ViewData["Title"] = "Договор — детали"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Договоры</a></li>
        <li class="breadcrumb-item active">Детали</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span>Договор @Model.ContractNumber</span>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.RequestId" class="btn btn-sm btn-outline-light">Изменить</a>
                <a asp-action="Delete" asp-route-id="@Model.RequestId" class="btn btn-sm btn-outline-danger">Удалить</a>
            </div>
        </div>
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4">Заявка</dt>
                <dd class="col-sm-8">#@Model.RequestId</dd>
                <dt class="col-sm-4">Номер договора</dt>
                <dd class="col-sm-8">@Model.ContractNumber</dd>
                <dt class="col-sm-4">Дата договора</dt>
                <dd class="col-sm-8">@Model.ContractDate.ToString("dd.MM.yyyy")</dd>
                <dt class="col-sm-4">Сумма</dt>
                <dd class="col-sm-8">@Model.Amount.ToString("N2") руб.</dd>
                <dt class="col-sm-4">Комиссия агента</dt>
                <dd class="col-sm-8">@(Model.AgentCommission.HasValue ? Model.AgentCommission.Value.ToString("N2") + " руб." : "—")</dd>
                <dt class="col-sm-4">Описание</dt>
                <dd class="col-sm-8">@(Model.Description ?? "—")</dd>
                <dt class="col-sm-4">Создан</dt>
                <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </div>
        <div class="card-footer bg-transparent">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Список</a>
        </div>
    </div>
</div></div>
