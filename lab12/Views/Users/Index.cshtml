@model IEnumerable<Lab12TVCompanyX.Models.User>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-people"></i> Пользователи</h2>
    <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Добавить</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle"></i> Пользователей нет.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle shadow-sm bg-white rounded">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>ФИО</th>
                    <th>Email</th>
                    <th>Роль</th>
                    <th>Телефон</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    string roleRu = u.Role?.Name switch {
                        "customer"   => "Заказчик",
                        "agent"      => "Агент",
                        "commercial" => "Коммерческий",
                        "accountant" => "Бухгалтер",
                        "admin"      => "Администратор",
                        "director"   => "Директор",
                        _            => u.Role?.Name ?? ""
                    };
                    <tr>
                        <td class="text-muted small">@u.UserId</td>
                        <td class="fw-semibold">@u.LastName @u.FirstName @u.MiddleName</td>
                        <td>@u.Email</td>
                        <td><span class="badge bg-secondary">@roleRu</span></td>
                        <td>@(u.Phone ?? "")</td>
                        <td>
                            @if (u.IsActive)
                            { <span class="badge bg-success">Активен</span> }
                            else
                            { <span class="badge bg-danger">Заблокирован</span> }
                        </td>
                        <td class="text-nowrap">
                            <a asp-action="Details" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-secondary" title="Просмотр"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit"    asp-route-id="@u.UserId" class="btn btn-sm btn-outline-dark"      title="Редактировать"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete"  asp-route-id="@u.UserId" class="btn btn-sm btn-outline-danger"    title="Удалить"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}