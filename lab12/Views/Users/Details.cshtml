@model Lab12TVCompanyX.Models.User
@{
    ViewData["Title"] = "Пользователь  " + Model.LastName + " " + Model.FirstName;
    string roleRu = Model.Role?.Name switch {
        "customer"   => "Заказчик",
        "agent"      => "Агент",
        "commercial" => "Коммерческий",
        "accountant" => "Бухгалтер",
        "admin"      => "Администратор",
        "director"   => "Директор",
        _            => Model.Role?.Name ?? ""
    };
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Пользователи</a></li>
        <li class="breadcrumb-item active">@Model.LastName @Model.FirstName</li>
    </ol>
</nav>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-dark text-white"><i class="bi bi-person-circle"></i> @Model.LastName @Model.FirstName @Model.MiddleName</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>
            <dt class="col-sm-4">Роль</dt>
            <dd class="col-sm-8"><span class="badge bg-secondary">@roleRu</span></dd>
            <dt class="col-sm-4">Телефон</dt>
            <dd class="col-sm-8">@(Model.Phone ?? "")</dd>
            <dt class="col-sm-4">Статус</dt>
            <dd class="col-sm-8">
                @if (Model.IsActive)
                { <span class="badge bg-success">Активен</span> }
                else
                { <span class="badge bg-danger">Заблокирован</span> }
            </dd>
        </dl>
    </div>
</div>

@if (Model.CustomerRequests?.Any() == true)
{
    <h5>Заявки как заказчик</h5>
    <table class="table table-sm table-bordered bg-white mb-4">
        <thead class="table-secondary"><tr><th>#</th><th>Шоу</th><th>Дата</th><th>Стоимость</th></tr></thead>
        <tbody>
            @foreach (var r in Model.CustomerRequests.OrderByDescending(x => x.CreatedAt))
            {
                <tr>
                    <td>@r.RequestId</td>
                    <td>@(r.Schedule?.TvShow?.Title ?? "")</td>
                    <td>@r.CreatedAt.ToString("dd.MM.yyyy")</td>
                    <td>@r.TotalCost.ToString("N2") </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (Model.AgentRequests?.Any() == true)
{
    <h5>Заявки как агент</h5>
    <table class="table table-sm table-bordered bg-white mb-4">
        <thead class="table-secondary"><tr><th>#</th><th>Шоу</th><th>Заказчик</th><th>Стоимость</th></tr></thead>
        <tbody>
            @foreach (var r in Model.AgentRequests.OrderByDescending(x => x.CreatedAt))
            {
                <tr>
                    <td>@r.RequestId</td>
                    <td>@(r.Schedule?.TvShow?.Title ?? "")</td>
                    <td>@(r.Customer != null ? $"{r.Customer.LastName} {r.Customer.FirstName}" : "")</td>
                    <td>@r.TotalCost.ToString("N2") </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-dark"><i class="bi bi-pencil"></i> Редактировать</a>
    <a asp-action="Index" class="btn btn-outline-secondary"> Назад</a>
</div>