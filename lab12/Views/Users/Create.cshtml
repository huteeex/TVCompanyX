@model Lab12TVCompanyX.Models.User
@{
    ViewData["Title"] = "Добавить пользователя";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Пользователи</a></li>
        <li class="breadcrumb-item active">Добавить</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white"><i class="bi bi-person-plus"></i> Новый пользователь</div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"
                         style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-4">
                            <label asp-for="LastName" class="form-label fw-semibold">Фамилия</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-4">
                            <label asp-for="FirstName" class="form-label fw-semibold">Имя</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-4">
                            <label asp-for="MiddleName" class="form-label fw-semibold">Отчество</label>
                            <input asp-for="MiddleName" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="user@example.ru" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label for="plainPassword" class="form-label fw-semibold">Пароль</label>
                        <input type="password" name="plainPassword" id="plainPassword" class="form-control"
                               placeholder="Будет захеширован SHA-256" />
                        <div class="form-text">Оставьте пустым, чтобы не задавать пароль.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-semibold">Телефон</label>
                        <input asp-for="Phone" class="form-control" placeholder="+7-999-000-0000" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Роль</label>
                        <select name="RoleId" class="form-select"
                                asp-items="@(ViewBag.Roles as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Активен</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark px-4"><i class="bi bi-check-lg"></i> Сохранить</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>