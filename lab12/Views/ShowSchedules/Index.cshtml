@model IEnumerable<Lab12TVCompanyX.Models.ShowSchedule>
@{ ViewData["Title"] = "Расписание эфиров"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-calendar3"></i> Расписание эфиров</h2>
    <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Добавить</a>
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover align-middle shadow-sm bg-white rounded">
        <thead class="table-dark"><tr><th>#</th><th>Телешоу</th><th>Дата</th><th>Время</th><th>Начало периода</th><th></th></tr></thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td class="text-muted small">@s.ScheduleId</td>
                    <td>@(s.TvShow?.Title ?? "—")</td>
                    <td>@s.AirDate.ToString("dd.MM.yyyy")</td>
                    <td>@s.AirTime.ToString(@"hh\:mm")</td>
                    <td class="small text-muted">@s.StartDatetime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-nowrap">
                        <a asp-action="Details" asp-route-id="@s.ScheduleId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit"    asp-route-id="@s.ScheduleId" class="btn btn-sm btn-outline-dark"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete"  asp-route-id="@s.ScheduleId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
