@model Lab12TVCompanyX.Models.ShowSchedule
@{ ViewData["Title"] = "Редактирование эфира"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Расписание</a></li>
        <li class="breadcrumb-item active">Редактировать</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">Редактирование записи #@Model.ScheduleId</div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ScheduleId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Телешоу</label>
                    <select name="TvShowId" class="form-select"
                            asp-items="@(ViewBag.TvShowId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                </div>
                <div class="mb-3">
                    <label asp-for="StartDatetime" class="form-label fw-semibold">Начало периода</label>
                    <input asp-for="StartDatetime" class="form-control" type="datetime-local" />
                    <span asp-validation-for="StartDatetime" class="text-danger small"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="AirDate" class="form-label fw-semibold">Дата эфира</label>
                        <input asp-for="AirDate" class="form-control" type="date" />
                        <span asp-validation-for="AirDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AirTime" class="form-label fw-semibold">Время эфира</label>
                        <input asp-for="AirTime" class="form-control" type="time" />
                        <span asp-validation-for="AirTime" class="text-danger small"></span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4">Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div></div>
