@model Lab12TVCompanyX.Models.ShowSchedule
@{ ViewData["Title"] = "Эфир — детали"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Расписание</a></li>
        <li class="breadcrumb-item active">Детали</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span>Запись расписания #@Model.ScheduleId</span>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.ScheduleId" class="btn btn-sm btn-outline-light">Изменить</a>
                <a asp-action="Delete" asp-route-id="@Model.ScheduleId" class="btn btn-sm btn-outline-danger">Удалить</a>
            </div>
        </div>
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4">Телешоу</dt>
                <dd class="col-sm-8">@(Model.TvShow?.Title ?? "—")</dd>
                <dt class="col-sm-4">Начало периода</dt>
                <dd class="col-sm-8">@Model.StartDatetime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt class="col-sm-4">Дата эфира</dt>
                <dd class="col-sm-8">@Model.AirDate.ToString("dd.MM.yyyy")</dd>
                <dt class="col-sm-4">Время эфира</dt>
                <dd class="col-sm-8">@Model.AirTime.ToString(@"hh\:mm")</dd>
                <dt class="col-sm-4">Обновлено</dt>
                <dd class="col-sm-8">@Model.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </div>
        <div class="card-footer bg-transparent">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Список</a>
        </div>
    </div>
</div></div>
