@model IEnumerable<Lab12TVCompanyX.Models.NotificationType>
@{ ViewData["Title"] = "Типы уведомлений"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-bell"></i> Типы уведомлений</h2>
    <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Добавить</a>
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover align-middle shadow-sm bg-white rounded">
        <thead class="table-dark"><tr><th>#</th><th>Название</th><th></th></tr></thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td class="text-muted small">@t.NotificationTypeId</td>
                    <td>@t.Name</td>
                    <td class="text-nowrap">
                        <a asp-action="Edit"   asp-route-id="@t.NotificationTypeId" class="btn btn-sm btn-outline-dark"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@t.NotificationTypeId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
