@model Lab12TVCompanyX.Models.Notification
@{ ViewData["Title"] = "Удаление уведомления"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Уведомления</a></li>
        <li class="breadcrumb-item active">Удалить</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0 border-danger">
        <div class="card-header bg-danger text-white">Подтверждение удаления</div>
        <div class="card-body p-4">
            <p class="text-danger mb-3">Вы уверены, что хотите удалить это уведомление?</p>
            <dl class="row mb-0">
                <dt class="col-sm-4">Тип</dt>
                <dd class="col-sm-8">@(Model.NotificationType?.Name ?? "—")</dd>
                <dt class="col-sm-4">Пользователь</dt>
                <dd class="col-sm-8">@(Model.User != null ? Model.User.LastName + " " + Model.User.FirstName : "—")</dd>
                <dt class="col-sm-4">Сообщение</dt>
                <dd class="col-sm-8">@(Model.Message.Length > 80 ? Model.Message[..80] + "…" : Model.Message)</dd>
            </dl>
        </div>
        <div class="card-footer bg-transparent d-flex gap-2">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="NotificationId" />
                <button type="submit" class="btn btn-danger">Удалить</button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </div>
</div></div>
