@model Lab12TVCompanyX.Models.Notification
@{ ViewData["Title"] = "Уведомление — детали"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Уведомления</a></li>
        <li class="breadcrumb-item active">Детали</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span>Уведомление #@Model.NotificationId</span>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.NotificationId" class="btn btn-sm btn-outline-light">Изменить</a>
                <a asp-action="Delete" asp-route-id="@Model.NotificationId" class="btn btn-sm btn-outline-danger">Удалить</a>
            </div>
        </div>
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4">Тип</dt>
                <dd class="col-sm-8">@(Model.NotificationType?.Name ?? "—")</dd>
                <dt class="col-sm-4">Пользователь</dt>
                <dd class="col-sm-8">@(Model.User != null ? Model.User.LastName + " " + Model.User.FirstName : "—")</dd>
                <dt class="col-sm-4">Сообщение</dt>
                <dd class="col-sm-8">@Model.Message</dd>
                <dt class="col-sm-4">Прочитано</dt>
                <dd class="col-sm-8">@(Model.IsRead ? "Да" : "Нет")</dd>
                <dt class="col-sm-4">Создано</dt>
                <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </div>
        <div class="card-footer bg-transparent">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Список</a>
        </div>
    </div>
</div></div>
