@model Lab12TVCompanyX.Models.Notification
@{ ViewData["Title"] = "Новое уведомление"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Уведомления</a></li>
        <li class="breadcrumb-item active">Добавить</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">Новое уведомление</div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Тип уведомления</label>
                    <select name="NotificationTypeId" class="form-select"
                            asp-items="@(ViewBag.NotificationTypeId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Пользователь</label>
                    <select name="UserId" class="form-select"
                            asp-items="@(ViewBag.UserId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                </div>
                <div class="mb-3">
                    <label asp-for="Message" class="form-label fw-semibold">Сообщение</label>
                    <textarea asp-for="Message" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Message" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input asp-for="IsRead" class="form-check-input" type="checkbox" />
                        <label asp-for="IsRead" class="form-check-label fw-semibold">Прочитано</label>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4">Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div></div>
