@model Lab12TVCompanyX.Models.ChatMessage
@{ ViewData["Title"] = "Новое сообщение"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Сообщения чата</a></li>
        <li class="breadcrumb-item active">Добавить</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">Новое сообщение</div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Заявка</label>
                    <select name="RequestId" class="form-select"
                            asp-items="@(ViewBag.RequestId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Отправитель</label>
                    <select name="SenderId" class="form-select"
                            asp-items="@(ViewBag.SenderId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                </div>
                <div class="mb-3">
                    <label asp-for="Content" class="form-label fw-semibold">Сообщение</label>
                    <textarea asp-for="Content" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4">Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div></div>
