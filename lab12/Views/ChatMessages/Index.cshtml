@model IEnumerable<Lab12TVCompanyX.Models.ChatMessage>
@{ ViewData["Title"] = "Сообщения чата"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Сообщения чата</h4>
    <a asp-action="Create" class="btn btn-dark btn-sm">+ Добавить</a>
</div>
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Заявка</th>
                    <th>Отправитель</th>
                    <th>Сообщение</th>
                    <th>Отправлено</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td>@m.MessageId</td>
                        <td>#@m.RequestId</td>
                        <td>@(m.Sender != null ? m.Sender.LastName + " " + m.Sender.FirstName : "—")</td>
                        <td>@(m.Content.Length > 60 ? m.Content[..60] + "…" : m.Content)</td>
                        <td>@m.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@m.MessageId" class="btn btn-sm btn-outline-secondary">Детали</a>
                            <a asp-action="Edit" asp-route-id="@m.MessageId" class="btn btn-sm btn-outline-primary">Изменить</a>
                            <a asp-action="Delete" asp-route-id="@m.MessageId" class="btn btn-sm btn-outline-danger">Удалить</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Сообщений нет</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
