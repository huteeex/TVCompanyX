@model Lab12TVCompanyX.Models.PaymentType
@{ ViewData["Title"] = "Способ оплаты #" + Model.PaymentTypeId; }
<div class="card shadow-sm border-0"><div class="card-header bg-dark text-white">@Model.Name</div>
<div class="card-body"><p><strong>#</strong> @Model.PaymentTypeId &nbsp; <strong>Название:</strong> @Model.Name</p></div></div>
<a asp-action="Edit" asp-route-id="@Model.PaymentTypeId" class="btn btn-dark mt-3">Редактировать</a>
<a asp-action="Index" class="btn btn-outline-secondary mt-3">← Назад</a>
