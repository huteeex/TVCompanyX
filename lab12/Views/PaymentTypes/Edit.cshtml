@model Lab12TVCompanyX.Models.PaymentType
@{ ViewData["Title"] = "Редактировать способ оплаты"; }
<div class="row justify-content-center"><div class="col-lg-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">Редактировать способ оплаты</div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PaymentTypeId" />
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Название</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark">Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div></div>
