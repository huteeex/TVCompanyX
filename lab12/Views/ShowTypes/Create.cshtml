@model Lab12TVCompanyX.Models.ShowType
@{ ViewData["Title"] = "Новый тип шоу"; }
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Типы телешоу</a></li>
        <li class="breadcrumb-item active">Добавить</li>
    </ol>
</nav>
<div class="row justify-content-center"><div class="col-lg-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white"><i class="bi bi-plus-lg"></i> Новый тип шоу</div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Название</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4"><i class="bi bi-check-lg"></i> Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div></div>
