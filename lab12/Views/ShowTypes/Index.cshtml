@model IEnumerable<Lab12TVCompanyX.Models.ShowType>
@{ ViewData["Title"] = "Типы телешоу"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-tags"></i> Типы телешоу</h2>
    <a asp-action="Create" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Добавить</a>
</div>
<div class="table-responsive">
    <table class="table table-striped table-hover align-middle shadow-sm bg-white rounded">
        <thead class="table-dark"><tr><th>#</th><th>Название</th><th>Шоу</th><th></th></tr></thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td class="text-muted small">@t.ShowTypeId</td>
                    <td>@t.Name</td>
                    <td class="text-muted small">@(t.TvShows?.Count ?? 0)</td>
                    <td class="text-nowrap">
                        <a asp-action="Details" asp-route-id="@t.ShowTypeId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit"    asp-route-id="@t.ShowTypeId" class="btn btn-sm btn-outline-dark"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete"  asp-route-id="@t.ShowTypeId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
