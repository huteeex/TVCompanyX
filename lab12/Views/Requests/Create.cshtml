@model Lab12TVCompanyX.Models.Request
@{
    ViewData["Title"] = "Новая заявка";
    var role = ViewBag.CurrentRole as string ?? "";
    var isAdmin = role == "admin" || role == "director";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Заявки</a></li>
        <li class="breadcrumb-item active">Новая заявка</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card animate-fadeInUp">
            <div class="card-header"><i class="bi bi-plus-lg"></i> Новая заявка</div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"
                         style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    @if (isAdmin)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Заказчик</label>
                            <select name="CustomerId" class="form-select"
                                    asp-items="@(ViewBag.CustomerId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Расписание эфира</label>
                        <select name="ScheduleId" class="form-select"
                                asp-items="@(ViewBag.ScheduleId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DurationSeconds" class="form-label fw-semibold">Длительность, сек</label>
                            <input asp-for="DurationSeconds" class="form-control" type="number" min="1" />
                            <span asp-validation-for="DurationSeconds" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TotalCost" class="form-label fw-semibold">Стоимость, ₽</label>
                            <input asp-for="TotalCost" class="form-control" type="number" step="0.01" lang="en" inputmode="decimal" />
                            <span asp-validation-for="TotalCost" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactPhone" class="form-label fw-semibold">Контактный телефон</label>
                        <input asp-for="ContactPhone" class="form-control" placeholder="+7 (900) 000-00-00" />
                        <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>

                    <hr class="my-3" />
                    <h6 class="text-muted">Оплата (необязательно)</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Способ оплаты</label>
                            <select name="PaymentTypeId" class="form-select"
                                    asp-items="@(ViewBag.PaymentTypeId as Microsoft.AspNetCore.Mvc.Rendering.SelectList)">
                                <option value="">— не выбран —</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PaymentDate" class="form-label fw-semibold">Дата оплаты</label>
                            <input asp-for="PaymentDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PaymentDueDate" class="form-label fw-semibold">Срок оплаты</label>
                            <input asp-for="PaymentDueDate" class="form-control" type="date" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> Подать заявку</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
